rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper Functions ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && request.auth.token.email == 'admin@primejar.in';
    }

    // ── Global Admin Access ─────────────────────────────────────
    // Ensures admin has full read/write capabilities across all collections
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    // ── Collections ─────────────────────────────────────────────

    // Users Collection
    match /users/{userId} {
      // Anyone authenticated can read user profiles (since organizers must see workers and vice versa).
      allow read: if isAuth(); 
      // Users can only create or update their own profile
      allow create, update: if isAuth() && request.auth.uid == userId;

      match /reviews/{reviewId} {
        allow read, write: if isAuth();
      }
    }

    // Jobs Collection
    match /jobs/{jobId} {
      // Authenticated users can see all available jobs
      allow read: if isAuth();
      allow create: if isAuth();
      // Only the organizer who created the job can edit it
      allow update: if isAuth() && resource.data.organizerId == request.auth.uid;
    }

    // Applications Collection
    match /applications/{appId} {
      allow read: if isAuth();
      // Workers must be applying for themselves
      allow create: if isAuth() && request.resource.data.workerId == request.auth.uid;
      // Either organizer or worker can update an application (e.g., status changes)
      allow update: if isAuth() && (resource.data.organizerId == request.auth.uid || resource.data.workerId == request.auth.uid);
    }

    // Activity Collection (Platform Events)
    match /activity/{docId} {
      // IMPORTANT: Only admins can read activity (prevents data leaks to ordinary users)
      allow read: if isAdmin();
      // Any authenticated user can create an activity log via client
      allow create: if isAuth();
    }

    // Notifications Collection
    match /notifications/{notifId} {
      allow read, write: if isAuth();
    }

    // Groups & Posts
    match /groups/{groupId} {
      allow read, write: if isAuth();
      match /posts/{postId} {
        allow read, write: if isAuth();
      }
    }

    // Conversations & Messages
    match /conversations/{convId} {
      allow read, write: if isAuth();
      match /messages/{msgId} {
        allow read, write: if isAuth();
      }
    }

    // Events
    match /events/{eventId} {
      allow read, write: if isAuth();
    }

    // Default Fallback
    // Ensure all other untested collections are locked by default
    match /{default=**} {
      allow read, write: if false;
    }
  }
}